[node name="Level3" instance=ExtResource("1_f8n4q")]
instructions = "Moving in a straight line won't work here. You need to change the robot's direction.

Use the \"turn\" block to rotate the robot. Notice the dropdown menu inside the block? Click it to toggle between \"left\" and \"right.\"

Remember: the robot always moves in the direction it is currently facing. Plan your turns carefully!"
intended_solution = "block: BeginBlock
  text: \"begin code\"
  children:
    - block: MoveBlock
      text: \"move forward\"
    - block: MoveBlock
      text: \"move forward\"
    - block: TurnBlock
      text: \"turn {}\"
      parameters:
        - \"right\"
    - block: MoveBlock
      text: \"move forward\"
    - block: MoveBlock
      text: \"move forward\"
"

